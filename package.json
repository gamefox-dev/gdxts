{
  "name": "gdxts",
  "version": "0.2.30",
  "type": "module",
  "dependencies": {
    "events": "^3.3.0"
  },
  "main": "./dist/gdxts.cjs",
  "module": "./dist/gdxts.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/gdxts.js",
      "require": "./dist/gdxts.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "prepare": "bun run build",
    "build": "vite build && bun run build:types",
    "build:demo": "vite build --mode demo",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview --mode demo"
  },
  "devDependencies": {
    "@types/offscreencanvas": "^2019.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
